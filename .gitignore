# python env — 930MB and not portable (absolute paths); recreate with uv
.venv/
__pycache__/
*.pyc

# model weights live in ~/Documents/Magenta, not the repo

# generated A/B sweep audio (engine/sweep_prompts.py, prototype/sweep_texture.py)
tex_*.wav

# secrets — ANTHROPIC_API_KEY etc. live in app/.env (loaded by npm start); never commit
app/.env

# misc
.DS_Store
*.log
*.output
app/hosttest.mjs

# NOTE: node_modules/ and external/ ARE committed (bundled for zero-install).
# Exception: vexflow — the runtime loads only the vendored browser build under
# app/public/vendor/vexflow (~560KB), so the full 32MB package is not committed.
app/node_modules/vexflow/

# pre-baked MRT2 voices (generated per taste)
app/public/voices/

# engine spike renders + logs (transient experiment output; scripts are committed)
engine/spike_out/*.wav
engine/*_log.txt
