# Copy to app/.env (gitignored) — `npm start` loads it automatically.

# Soundscape translation of player taste prompts (claude-haiku-4-5).
# REQUIRED for taste-personalized texture: without it, prompts are left out of
# the texture blend (default ambient bed) — raw prompts corrupt the texture
# into songs, so there is no offline fallback. Instrument voices (prebake)
# still personalize either way.
ANTHROPIC_API_KEY=sk-ant-...

# Other knobs (all optional):
# NO_TEXTURE=1   — run without the MRT2 texture engine
# NO_TUNNEL=1    — LAN-only, skip the cloudflare tunnel
# PUBLIC_URL=    — pin an explicit join URL instead of the auto tunnel
# PORT=3000
